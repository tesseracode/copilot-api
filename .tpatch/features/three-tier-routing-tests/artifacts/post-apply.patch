+  // Low effort: disable thinking entirely for speed
+  if (effort === "low") {
+    return { type: "disabled" }
+  }
+
+  // If no thinking config and no effort signal, nothing to do
+  if (!thinking && !effort) return undefined
+
+  const type = thinking?.type ?? "enabled"
+  let budgetTokens = thinking?.budget_tokens
+
+  // Downgrade 'adaptive' to 'enabled' — Copilot doesn't support adaptive
+  if (type === "adaptive" || type === "enabled") {
+    // Apply effort-based budget when thinking is enabled
+    switch (effort) {
+      case "medium": {
+        budgetTokens =
+          budgetTokens ?? Math.max(1024, Math.floor(maxTokens * 0.5))
+
+        break
+      }
+      case "high": {
+        budgetTokens =
+          budgetTokens ?? Math.max(1024, Math.floor(maxTokens * 0.8))
+
+        break
+      }
+      case "max": {
+        budgetTokens = Math.max(1024, maxTokens - 1)
+
+        break
+      }
+      default: {
+        budgetTokens = budgetTokens ?? Math.max(1024, maxTokens - 1)
+      }
     }
+    return { type: "enabled", budget_tokens: budgetTokens }
   }
+
   return thinking
 }
 
